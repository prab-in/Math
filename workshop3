        "plt.grid()\n",
        "\n",
        "plt.xlabel(\"X\")\n",
        "\n",
        "plt.ylabel(\"Y\")\n",
        "\n",
        "plt.title(\"Ellipse centered at (2,2) with a=3 , b=5\")\n",
        "\n",
        "# Equal aspect ration to avoid stretching\n",
        "\n",
        "ax= plt.gca()\n",
        "\n",
        "ax.set_aspect('equal',adjustable='box')\n",
