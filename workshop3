        "import matplotlib.pyplot as plt\n",
        "\n",
        "import math\n",
        "\n",
        "# parabola parameters\n",
        "\n",
        "q=0 # y-coordinate of vertex\n",
        "\n",
        "p=0 # x-coordinate of vertex\n",
        "\n",
        "a=0.5 # controls width and direction\n",
        "\n",
        "# Step size for x values\n",
        "\n",
        "step_size = 0.1\n",
        "\n",
        "# define x range aroung vertex\n",
        "\n",
        "y_start = p-5\n",
        "\n",
        "y_end = p + 5\n",
        "\n",
        "# lists to store coordinates\n",
        "\n",
        "x_values =[]\n",
        "\n",
        "y_values =[]\n",
        "\n",
        "#initialize x\n",
        "\n",
        "y = y_start\n",
        "\n",
        "# generate poinst for parabola\n",
        "\n",
        "while y <= y_end:\n",
        "\n",
        "  x = 4*a*(y-p)**2+p\n",
        "\n",
        "  x_values.append(x)\n",
        "\n",
        "  y_values.append(y)\n",
        "\n",
        "  y += step_size\n",
        "\n",
        "#plot the graph\n",
        "\n",
        "plt.figure()\n",
        "\n",
        "plt.title(f\"Parabola with vertex at ({p},{q}) and a ={a}\")\n",
        "\n",
        "plt.plot(x_values,y_values,'-')\n",
        "\n",
        "plt.grid()\n",
        "\n",
        "plt.xlabel(\"X\")\n",
        "\n",
        "plt.ylabel(\"Y\")\n",
        "\n",
        "plt.show()"
