        "# step sizes to sample the paramater Theta\n",
        "\n",
        "step_size= 0.125\n",
        "\n",
        "#math.ceil() → round up to nearest integer\n",
        "\n",
        "# Number of samples\n",
        "\n",
        "steps = math.ceil((theta_end-theta_start)/step_size)\n",
